# TrustGuard Configuration
# Copy to .env: cp .env.example .env

# Application
APP_NAME=TrustGuard
APP_VERSION=1.0.0
DEBUG=True

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (SQLite by default, no setup needed)
DATABASE_URL=sqlite:///./trustguard.db

# Detection Thresholds
DEEPFAKE_THRESHOLD=0.5
LIVENESS_THRESHOLD=0.7

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trustguard.log
